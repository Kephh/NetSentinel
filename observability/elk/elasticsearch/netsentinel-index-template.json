{
  "index_patterns": [
    "netsentinel-audit-*"
  ],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "dynamic": true,
      "properties": {
        "timestamp": {
          "type": "date"
        },
        "routeId": {
          "type": "keyword"
        },
        "backendId": {
          "type": "keyword"
        },
        "method": {
          "type": "keyword"
        },
        "uri": {
          "type": "wildcard"
        },
        "statusCode": {
          "type": "integer"
        },
        "latencyNanos": {
          "type": "long"
        },
        "latencyMs": {
          "type": "scaled_float",
          "scaling_factor": 1000
        },
        "success": {
          "type": "boolean"
        }
      }
    }
  },
  "priority": 400,
  "_meta": {
    "description": "NetSentinel traffic audit template"
  }
}
