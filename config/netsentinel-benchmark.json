{
  "server": {
    "host": "127.0.0.1",
    "port": 8080,
    "managementPort": 9090,
    "redisUri": "",
    "rateLimit": {
      "enabled": false,
      "capacity": 1000,
      "refillPerSecond": 500
    }
  },
  "security": {
    "inboundTls": {
      "enabled": false,
      "certificateChainPath": "",
      "privateKeyPath": "",
      "trustCertificatePath": "",
      "requireClientAuth": false
    },
    "backendTls": {
      "enabled": false,
      "certificateChainPath": "",
      "privateKeyPath": "",
      "trustCertificatePath": "",
      "requireClientAuth": false
    }
  },
  "waf": {
    "enabled": false,
    "patterns": []
  },
  "health": {
    "intervalSeconds": 60,
    "failureThreshold": 3,
    "timeoutMillis": 500
  },
  "audit": {
    "enabled": false,
    "sink": "stdout",
    "filePath": "logs/netsentinel-audit.log",
    "kafkaBootstrapServers": "",
    "kafkaTopic": "netsentinel-traffic"
  },
  "routes": [
    {
      "id": "benchmark",
      "host": "*",
      "headers": {},
      "policy": "LEAST_RESPONSE_TIME",
      "backends": [
        {
          "id": "backend-local",
          "uri": "http://127.0.0.1:9001",
          "weight": 100,
          "healthPath": "/"
        }
      ]
    }
  ]
}
